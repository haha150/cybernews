# === CyberNews Aggregator Configuration ===

# Backend port (internal)
BACKEND_PORT=8000

# Frontend port (browser access)
FRONTEND_PORT=8080

# SQLite database path (inside container)
DB_PATH=/app/data/cybernews.db

# Feed refresh interval in minutes (default: 15)
REFRESH_INTERVAL_MINUTES=15

# CVE enrichment check interval in minutes (default: 5)
ENRICHMENT_INTERVAL_MINUTES=5

# Enrichment cache TTL in hours (default: 6)
ENRICHMENT_TTL_HOURS=6

# NVD API Key (optional — increases rate limit from 5 to 50 req/30s)
# Get one at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Path to feeds config (default: feeds.json)
FEEDS_PATH=feeds.json
