# === CyberNews Aggregator Configuration ===

# Backend port (internal)
BACKEND_PORT=8000

# Frontend port (browser access — HTTP)
FRONTEND_PORT=8080

# HTTPS port (browser access — TLS, requires certs)
HTTPS_PORT=8443

# SSL certificate directory (must contain cert.pem and key.pem)
# If certs are not found, the app serves HTTP only
SSL_CERT_DIR=./certs

# SQLite database path (inside container)
DB_PATH=/app/data/cybernews.db

# DB connection pool size
DB_POOL_SIZE=5

# Article retention in days (older articles are auto-deleted)
RETENTION_DAYS=30

# Feed refresh interval in minutes (default: 15)
REFRESH_INTERVAL_MINUTES=15

# CVE enrichment check interval in minutes (default: 5)
ENRICHMENT_INTERVAL_MINUTES=5

# Enrichment cache TTL in hours (default: 6)
ENRICHMENT_TTL_HOURS=6

# NVD API Key (optional — increases rate limit from 5 to 50 req/30s)
# Get one at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Path to feeds config (default: feeds.json)
FEEDS_PATH=feeds.json

# CORS allowed origins (comma-separated). Default: * (allow all)
# Example: https://cybernews.example.com,https://admin.example.com
CORS_ORIGINS=

# Optional HTTP Basic Auth (leave empty to disable)
AUTH_USERNAME=
AUTH_PASSWORD=

# Rate limit — max requests per minute on mutating endpoints (default: 30)
RATE_LIMIT_RPM=30
